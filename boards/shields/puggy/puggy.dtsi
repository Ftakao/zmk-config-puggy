#include <dt-bindings/zmk/matrix_transform.h>

#include "puggy-layouts.dtsi"

#define ENCODER_STEPS 48

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-charlieplex";
    };

    left_encoder1: left_encoder_1 {
        compatible = "alps,ec11";
        steps = <ENCODER_STEPS>;
        status = "disabled";
    };

    left_encoder2: left_encoder_2 {
        compatible = "alps,ec11";
        steps = <ENCODER_STEPS>;
        status = "disabled";
    };

    right_encoder1: right_encoder_1 {
        compatible = "alps,ec11";
        steps = <ENCODER_STEPS>;
        status = "disabled";
    };

    right_encoder2: right_encoder_2 {
        compatible = "alps,ec11";
        steps = <ENCODER_STEPS>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <
            &left_encoder1
            &left_encoder2
            &right_encoder1
            &right_encoder2
        >;
        triggers-per-rotation = <24>;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
        map = <
            // Swap row/col indexes from the schematic
            // Right-side: rows are offset by +6
            // --- left ---                                                                 --- right ---
            RC( 5,  1) RC( 5,  0) RC( 4,  0) RC( 3,  0) RC( 2,  0) RC( 1,  0)                          RC( 7,  0) RC( 8,  0) RC( 9,  0) RC(10,  0) RC(11,  0) RC(11,  1)
            RC( 5,  2) RC( 4,  2) RC( 4,  1) RC( 3,  1) RC( 2,  1) RC( 1,  2) RC( 0,  2)    RC( 6,  2) RC( 7,  2) RC( 8,  1) RC( 9,  1) RC(10,  1) RC(10,  2) RC(11,  2)
            RC( 5,  3) RC( 4,  3) RC( 3,  4) RC( 3,  2) RC( 2,  3) RC( 1,  3) RC( 0,  3)    RC( 6,  3) RC( 7,  3) RC( 8,  3) RC( 9,  2) RC( 9,  4) RC(10,  3) RC(11,  3)
            RC( 5,  4) RC( 4,  5) RC( 3,  5) RC( 2,  4) RC( 2,  5) RC( 1,  5) RC( 0,  5)    RC( 6,  5) RC( 7,  5) RC( 8,  5) RC( 8,  4) RC( 9,  5) RC(10,  5) RC(11,  4)
        >;
    };
};

/ {
    chg_stat: chg_stat {
        compatible = "custom,chg-stat";
        status = "okay";
        gpios = <&gpio0 17 GPIO_ACTIVE_LOW>;
    };
};
